# ===========================
# Application Configuration
# ===========================
APP_NAME="Blockchain Blood Bank Management System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_VERSION=1.0.0-alpha

# ===========================
# Database Configuration
# ===========================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=blood_bank_management
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# ===========================
# Session Configuration
# ===========================
SESSION_NAME=BBMID
SESSION_TIMEOUT=3600
SESSION_SECURE=false
SESSION_HTTPONLY=true

# ===========================
# Blockchain Configuration
# ===========================
BLOCKCHAIN_NETWORK=ganache-local
BLOCKCHAIN_HOST=http://127.0.0.1:7545
BLOCKCHAIN_PORT=7545
BLOCKCHAIN_CHAIN_ID=5777

# ===========================
# Smart Contract Addresses
# ===========================
# Set after contract deployment
BLOOD_DONATION_CONTRACT=0x
BLOOD_TRANSFER_CONTRACT=0x
REQUEST_APPROVAL_CONTRACT=0x
BLOOD_BANK_CONTRACT=0x

# ===========================
# Web3.js Configuration
# ===========================
WEB3_PROVIDER=http://127.0.0.1:7545
WEB3_GAS_LIMIT=8000000
WEB3_GAS_PRICE=2000000000

# ===========================
# MetaMask Configuration
# ===========================
METAMASK_ENABLED=true
METAMASK_NETWORK_ID=5777
METAMASK_NETWORK_NAME=Ganache
METAMASK_RPC_URL=http://127.0.0.1:7545

# ===========================
# Email Configuration (Optional)
# ===========================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=465
MAIL_FROM=noreply@bloodbank.local
MAIL_USERNAME=
MAIL_PASSWORD=

# ===========================
# SMS Configuration (Optional)
# ===========================
SMS_ENABLED=false
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=

# ===========================
# File Upload Configuration
# ===========================
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
UPLOAD_PATH=uploads/
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# ===========================
# Security Configuration
# ===========================
SECRET_KEY=your-secret-key-here-change-in-production
SALT_ROUNDS=10
CSRF_TOKEN_NAME=csrf_token
CSRF_TOKEN_EXPIRY=3600

# ===========================
# Logging Configuration
# ===========================
LOG_LEVEL=info
LOG_PATH=logs/
LOG_FILE_SIZE=10485760  # 10MB

# ===========================
# API Configuration
# ===========================
API_RATE_LIMIT=100
API_RATE_WINDOW=3600
API_VERSION=v1

# ===========================
# CORS Configuration
# ===========================
CORS_ENABLED=false
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_HEADERS=Content-Type,Authorization

# ===========================
# QR Code Configuration
# ===========================
QRCODE_SIZE=200
QRCODE_ERROR_CORRECTION=M
QRCODE_FORMAT=png

# ===========================
# Report Configuration
# ===========================
REPORT_FORMAT=pdf
REPORT_STORAGE=local
REPORT_PATH=uploads/reports/

# ===========================
# Cache Configuration
# ===========================
CACHE_DRIVER=file
CACHE_TTL=3600

# ===========================
# Development Tools
# ===========================
XDEBUG_ENABLED=false
XDEBUG_HOST=127.0.0.1
XDEBUG_PORT=9003

# ===========================
# Feature Flags (Beta Features)
# ===========================
FEATURE_AI_PREDICTION=false
FEATURE_IOT_MONITORING=false
FEATURE_MOBILE_APP=false
FEATURE_SMS_NOTIFICATIONS=false
FEATURE_EMAIL_NOTIFICATIONS=false
FEATURE_ADVANCED_ANALYTICS=false

# ===========================
# Maintenance Mode
# ===========================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=System is under maintenance. Please try again later.
